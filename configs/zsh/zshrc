zsh_dir="$HOME"/.config/zsh
shoichi_dir="$zsh_dir"/shoichi
export EDITOR=nvim

# Enable emacs key bindings (Ctrl+A, Ctrl+E, etc.)
bindkey -e

#----- LANG -----#
# LC_ALL は全 LC_* カテゴリを最優先で上書きし、OS 別設定
# (config-linux.zsh の LANG/LC_CTYPE) を無効化してしまうため設定しない
export LANG=ja_JP.UTF-8

#----- setup prompt -----#
# 注意: zsh では `prompt` は PS1 の別名（特殊変数）のため使わない
prompt_type="starship"
case $prompt_type in
    oh-my-zsh)
        source $shoichi_dir/oh-my-zsh.zsh
        ;;
    starship)
        export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml"
        eval "$(starship init zsh)"
        ;;
    *)
        echo "Unknown prompt: $prompt_type"
        ;;
esac
unset prompt_type

#----- setup zsh on each systems -----#
os_type=$(uname)
case "$os_type" in
    Linux)
        source $shoichi_dir/config-linux.zsh
        ;; 
    Darwin)
        source $shoichi_dir/config-osx.zsh
        ;;
    CYGWIN*|MINGW32*|MSYS*|MINGW*)
        ;;
    *)
        echo "Unknown OS: $os_type"
        ;;
esac

#----- completion -----#
# starship 経路では oh-my-zsh が compinit を呼ばないため、ここで初期化する
# （これがないと compdef ベースの補完や fzf の **<TAB> が機能しない）
autoload -Uz compinit && compinit

#----- import other settings -----#
source $shoichi_dir/command-extensions.zsh
source $shoichi_dir/alias.zsh

# for warp terminal settings
## change the font to Meslo Nerd Font
## https://docs.warp.dev/appearance/prompt#powerlevel10k

# Android Studio JDK (openjdk が存在する場合のみ)
if [ -d /opt/homebrew/opt/openjdk/bin ]; then
  export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"
fi

# Auto-rename tmux session and window to current directory name
_tmux_rename() {
  [ -n "$TMUX" ] || return 0
  # ディレクトリが変わった時だけ実行する。毎プロンプト実行すると
  # fork のオーバーヘッドに加え、手動リネームが即座に潰され、
  # 同名ディレクトリの複数セッションで duplicate session name エラーが出続ける
  [ "$PWD" = "${_tmux_rename_last_pwd-}" ] && return 0
  _tmux_rename_last_pwd="$PWD"
  tmux rename-session "$(basename "$PWD")" 2>/dev/null
  tmux rename-window "$(basename "$PWD")"
}
precmd_functions+=(_tmux_rename)

if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi
export PATH="$HOME/.local/bin:$PATH"

# ---- Zoxide (better cd) ----
# zoxide init は zshrc の一番最後に置く（PATH 変更や alias 定義より
# 後でないと zoxide doctor が警告を出す）。--cmd cd で cd 自体を置き換える。
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh --cmd cd)"
fi
